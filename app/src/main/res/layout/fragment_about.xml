<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    tools:context=".ui.about.AboutFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Стоп Энурез"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAboutSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Приложение для ночного аудиоконтроля и раннего пробуждения ребёнка"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <TextView
            android:id="@+id/tvHowItWorksHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Как это работает"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHowItWorks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="• Ночью приложение слушает звуки рядом с кроватью.\n• В режиме обучения родители размечают моменты ёрзания.\n• На основе аудиопризнаков обучается локальная модель.\n• В режиме использования приложение распознаёт ёрзание и включает будильник."
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/tvAdvantagesHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Преимущества"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdvantages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="• Полностью оффлайн\n• Без регистрации\n• Локальное хранение данных\n• Подстройка под конкретного ребёнка и комнату\n• Возможность дообучения после ложных срабатываний"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/tvReminderHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Важно"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Приложение является вспомогательным инструментом и не заменяет консультацию специалиста."
            android:textAppearance="?attr/textAppearanceBodyMedium" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
