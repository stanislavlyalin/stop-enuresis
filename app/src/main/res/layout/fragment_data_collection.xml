<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    tools:context=".ui.DataCollectionFragment">

    <TextView
        android:id="@+id/tvDataCollectionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/collectData"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/chartContainer"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDataCollectionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChartAmplitude"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvThresholdLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/volumeThreshold"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/chartContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SeekBar
        android:id="@+id/seekBarThreshold"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="35"
        app:layout_constraintTop_toBottomOf="@id/tvThresholdLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSilenceCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/silenceCounterInitial"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="#2E7D32"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/seekBarThreshold"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="тишина: 0" />

    <TextView
        android:id="@+id/tvRustlingCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/rustlingCounterInitial"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="#C62828"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/seekBarThreshold"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="ёрзает: 0" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAudioFragments"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:itemCount="2"
        tools:listitem="@layout/item_audio_fragment_placeholder"
        app:layout_constraintTop_toBottomOf="@id/tvSilenceCounter"
        app:layout_constraintBottom_toTopOf="@id/btnRecordToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnRecordToggle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/startRecording"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
