<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".ui.UsageFragment">

    <TextView
        android:id="@+id/tvUsageStatusCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_training_status_circle"
        android:gravity="center"
        android:text="@string/usageHello"
        android:textAlignment="center"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        app:layout_constraintBottom_toTopOf="@id/tvNextAlarmAllowed"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvNextAlarmAllowed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnUsageMain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvUsageStatusCircle"
        tools:text="Следующее срабатывание не ранее 07:30"
        tools:visibility="visible" />

    <Button
        android:id="@+id/btnUsageMain"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="180dp"
        android:text="@string/startListening"
        app:layout_constraintBottom_toTopOf="@id/layoutUsageFeedback"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNextAlarmAllowed" />

    <LinearLayout
        android:id="@+id/layoutUsageFeedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnUsageMain"
        tools:visibility="visible">

        <Button
            android:id="@+id/btnFalseAlarm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/falseAlarm" />

        <Button
            android:id="@+id/btnSuccess"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/success" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
